{
  "scope": "aux4",
  "name": "jobs",
  "version": "1.0.2",
  "description": "Background job manager for aux4",
  "license": "Apache-2.0",
  "tags": [
    "aux4",
    "jobs",
    "background",
    "process"
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "jobs",
          "execute": [
            "profile:jobs"
          ],
          "help": {
            "text": "Background job management"
          }
        }
      ]
    },
    {
      "name": "jobs",
      "commands": [
        {
          "name": "run",
          "execute": [
            "${packageDir}/aux4-jobs run values(command, onSuccess, onFailure, onComplete)"
          ],
          "help": {
            "text": "Run a command in the background",
            "variables": [
              {
                "name": "command",
                "text": "Command to run in the background",
                "arg": true
              },
              {
                "name": "onSuccess",
                "text": "Command to run on success (exit code 0)",
                "default": ""
              },
              {
                "name": "onFailure",
                "text": "Command to run on failure (non-zero exit code)",
                "default": ""
              },
              {
                "name": "onComplete",
                "text": "Command to run on completion (any terminal state)",
                "default": ""
              }
            ]
          }
        },
        {
          "name": "list",
          "execute": [
            "${packageDir}/aux4-jobs list value(state)"
          ],
          "help": {
            "text": "List jobs",
            "variables": [
              {
                "name": "state",
                "text": "Filter by state",
                "default": "",
                "options": [
                  "RUNNING",
                  "COMPLETED",
                  "FAILED",
                  "KILLED"
                ]
              }
            ]
          }
        },
        {
          "name": "status",
          "execute": [
            "${packageDir}/aux4-jobs status value(id)"
          ],
          "help": {
            "text": "Show job status",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "output",
          "execute": [
            "${packageDir}/aux4-jobs output values(id, stream)"
          ],
          "help": {
            "text": "Show job output",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              },
              {
                "name": "stream",
                "text": "Output stream",
                "default": "stdout",
                "options": [
                  "stdout",
                  "stderr"
                ]
              }
            ]
          }
        },
        {
          "name": "tail",
          "execute": [
            "alias:${packageDir}/aux4-jobs tail values(id, stream)"
          ],
          "help": {
            "text": "Tail job output in real time",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              },
              {
                "name": "stream",
                "text": "Output stream",
                "default": "stdout",
                "options": [
                  "stdout",
                  "stderr"
                ]
              }
            ]
          }
        },
        {
          "name": "kill",
          "execute": [
            "${packageDir}/aux4-jobs kill value(id)"
          ],
          "help": {
            "text": "Kill a running job",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              }
            ]
          }
        },
        {
          "name": "killall",
          "execute": [
            "${packageDir}/aux4-jobs killall"
          ],
          "help": {
            "text": "Kill all running jobs"
          }
        }
      ]
    }
  ]
}
