{
  "scope": "aux4",
  "name": "jobs",
  "version": "1.1.0",
  "description": "Background job manager for aux4",
  "license": "Apache-2.0",
  "tags": [
    "aux4",
    "jobs",
    "background",
    "process"
  ],
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "jobs",
          "execute": [
            "profile:jobs"
          ],
          "help": {
            "text": "Background job management"
          }
        }
      ]
    },
    {
      "name": "jobs",
      "commands": [
        {
          "name": "run",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) run values(command, onSuccess, onFailure, onComplete, source, cleanup)"
          ],
          "help": {
            "text": "Run a command in the background",
            "variables": [
              {
                "name": "command",
                "text": "Command to run in the background",
                "arg": true
              },
              {
                "name": "onSuccess",
                "text": "Command to run on success (exit code 0)",
                "default": ""
              },
              {
                "name": "onFailure",
                "text": "Command to run on failure (non-zero exit code)",
                "default": ""
              },
              {
                "name": "onComplete",
                "text": "Command to run on completion (any terminal state)",
                "default": ""
              },
              {
                "name": "source",
                "text": "Tag identifying who created the job (for filtering)",
                "default": ""
              },
              {
                "name": "cleanup",
                "text": "Remove the job directory after completion",
                "default": "false",
                "options": [
                  "true",
                  "false"
                ]
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "list",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) list values(state, source)"
          ],
          "help": {
            "text": "List jobs",
            "variables": [
              {
                "name": "state",
                "text": "Filter by state",
                "default": "",
                "options": [
                  "RUNNING",
                  "COMPLETED",
                  "FAILED",
                  "KILLED"
                ]
              },
              {
                "name": "source",
                "text": "Filter by source tag",
                "default": ""
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "status",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) status value(id)"
          ],
          "help": {
            "text": "Show job status",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "output",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) output values(id, stream)"
          ],
          "help": {
            "text": "Show job output",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              },
              {
                "name": "stream",
                "text": "Output stream",
                "default": "stdout",
                "options": [
                  "stdout",
                  "stderr"
                ]
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "tail",
          "execute": [
            "alias:${packageDir}/aux4-jobs --path value(path) tail values(id, stream)"
          ],
          "help": {
            "text": "Tail job output in real time",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              },
              {
                "name": "stream",
                "text": "Output stream",
                "default": "stdout",
                "options": [
                  "stdout",
                  "stderr"
                ]
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "kill",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) kill value(id)"
          ],
          "help": {
            "text": "Kill a running job",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "on",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) on values(id, success, failure, complete)"
          ],
          "help": {
            "text": "Register callbacks on a running job",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              },
              {
                "name": "success",
                "text": "Command to run on success (exit code 0)",
                "default": ""
              },
              {
                "name": "failure",
                "text": "Command to run on failure (non-zero exit code)",
                "default": ""
              },
              {
                "name": "complete",
                "text": "Command to run on completion (any terminal state)",
                "default": ""
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "attach",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) attach values(pid, command, stdout, stderr, source)"
          ],
          "help": {
            "text": "Attach a running process to the jobs system",
            "variables": [
              {
                "name": "pid",
                "text": "Process ID to attach",
                "arg": true
              },
              {
                "name": "command",
                "text": "Command description (for display purposes)",
                "arg": true
              },
              {
                "name": "stdout",
                "text": "Path to stdout file being written by the process",
                "default": ""
              },
              {
                "name": "stderr",
                "text": "Path to stderr file being written by the process",
                "default": ""
              },
              {
                "name": "source",
                "text": "Tag identifying who created the job (for filtering)",
                "default": ""
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "killall",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) killall"
          ],
          "help": {
            "text": "Kill all running jobs",
            "variables": [
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "remove",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) remove values(id, force)"
          ],
          "help": {
            "text": "Remove a finished job from storage",
            "variables": [
              {
                "name": "id",
                "text": "Job ID",
                "arg": true
              },
              {
                "name": "force",
                "text": "Force removal even if the job is still running (kills it first)",
                "default": "false",
                "options": [
                  "true",
                  "false"
                ]
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        },
        {
          "name": "remove-all",
          "execute": [
            "${packageDir}/aux4-jobs --path value(path) remove-all values(state, source)"
          ],
          "help": {
            "text": "Remove all finished jobs (optionally filtered by state or source)",
            "variables": [
              {
                "name": "state",
                "text": "Filter by state",
                "default": "",
                "options": [
                  "COMPLETED",
                  "FAILED",
                  "KILLED"
                ]
              },
              {
                "name": "source",
                "text": "Filter by source tag",
                "default": ""
              },
              {
                "name": "path",
                "text": "Custom jobs storage directory",
                "default": ".jobs"
              }
            ]
          }
        }
      ]
    }
  ]
}
